{
  "expo": {
    "name": "Rinsebase",
    "slug": "rinse-base-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rinsebase.app"
    },
    "android": {
      "package": "com.rinsebase.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Rinsebase uses your location for SOS emergency alerts.",
          "locationWhenInUsePermission": "Rinsebase uses your location for SOS emergency alerts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4768586a-ae45-4b35-984c-a1803f1b2985"
      }
    },
    "owner": "photomacs-organization"
  }
}
